
# Load custom Tokyo Night theme
theme = tokyo-night

# Transparency & blur
background-opacity = 0.85
background-blur = 15

# Font settings
font-family = "JetBrains Mono Nerd Font"
font-size = 13

# Window size & padding
window-width = 90
window-height = 28
window-padding-x = 4
window-padding-y = 4

# Static title & state
title = "Ghostty Terminal"
window-save-state = always

# Start in home directory
working-directory = "~"

# Cursor & mouse
cursor-style = "block"
cursor-style-blink = true
cursor-click-to-move = true
mouse-hide-while-typing = true

# Selection highlight
selection-background = "#7aa2f7"

# Scrollback buffer (10 000 lines)
scrollback-limit = 10000

# Shell integration (Fish + Starship prompt)
shell-integration = "fish"
initial-command = "fish"
