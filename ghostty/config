# Theme and Appearance
theme = catppuccin-mocha
background-opacity = 0.85
background-blur = 15
background-blur-radius = 20
background-blur-sigma = 10

# Font Configuration
font-family = JetBrains Mono Nerd Font
font-size = 13
font-weight = 400
font-features = "cv01,cv02,cv03,cv04,ss01,ss02,ss03,ss04,ss05,ss06,zero,onum"

# Window Settings
window-width = 90
window-height = 28
window-padding-x = 4
window-padding-y = 4
window-title = "Ghostty Terminal"
window-save-state = always
working-directory = home

# Cursor and Selection
cursor-style = block
cursor-blink = true
cursor-blink-interval = 500
selection-foreground = auto
selection-background = #89b4fa

# Mouse and Focus
focus-follows-mouse = true
mouse-hide-while-typing = true
enable-mouse = true

# Scrolling and History
scrollback-limit = 10000
scrollback-multiplier = 3
scrollback-pager = less
scrollback-pager-mouse = true

# Keybindings
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+plus=increase_font_size
keybind = ctrl+shift+minus=decrease_font_size
keybind = ctrl+shift+0=reset_font_size
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Performance and Rendering
sync-to-monitor = true
enable-ligatures = true
box-drawing-uses-font-glyphs = true
disable-ligatures-never = true

# Bell and Notifications
enable-bell = true
bell-on-alert = true
bell-duration = 200

# URL Detection
url-launcher = xdg-open
url-detection = true
url-style = curly
url-prefixes = http,https,ftp,ftps,file,mailto,news,irc,ircs,git,ssh,rsync,smb,smb,file
